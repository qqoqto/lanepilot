{
  "expo": {
    "name": "LanePilot",
    "slug": "lanepilot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lanepilot.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "LanePilot 需要您的位置來顯示附近的國道路況資訊",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "LanePilot 需要背景定位來提供即時車道建議與路況通知",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.lanepilot.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "0c3db3ad-9b61-4564-90ae-0157d60a73c4"
      }
    },
    "owner": "xj9"
  }
}
